

int main(){
    // Your binary encoded message
    uint8_t binary_data[] = {{c_array}};
    size_t binary_size = sizeof(binary_data);

    // Output structure
    {{schema_name}}_t *obj = 0;

    // Decode using UPER
    asn_dec_rval_t rval = uper_decode(0, &asn_DEF_{{schema_name}},
                                      (void **)&obj, binary_data, binary_size, 0, 0);

    if (rval.code != RC_OK) {
        printf("Decoding failed!\n");
        return -1;
    }

    cJSON *json = {{schema_name}}_to_json(obj);
    if (json) {
        char *json_string = cJSON_Print(json);  // Use cJSON_PrintUnformatted(json) for compact output
        if (json_string) {
            printf("JSON Output:\n%s\n", json_string);
            free(json_string);  // Must free the printed string
        }
        cJSON_Delete(json);  // Free the cJSON object
    }

    // Free ASN.1 decoded structure
    ASN_STRUCT_FREE(asn_DEF_{{schema_name}}, obj);

    return 0;
}