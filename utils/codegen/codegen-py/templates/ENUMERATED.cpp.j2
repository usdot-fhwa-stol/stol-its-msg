#include "json.hpp"

{%- for include in includes %}
#include "{{ include.name }}"
{%- endfor %}

using json = nlohmann::json;

/*


{% if comments %}
{%- for comment in comments %}
{{ comment }}
{%- endfor %}
{%- endif %}

*/

constexpr const char* {{ function_name }}_to_string({{ struct_name }} obj) {
    switch (obj) {
        {%- for member in members %}
        case {{ function_name }}_{{ member.name }}: return "{{ member.name }}";
        {%- endfor %}
        default: return "unknown";
    }
}

json to_JSON_{{ function_name }}(const {{ struct_name }}& obj) {
    return json({{ function_name }}_to_string(obj));
}

{{ struct_name }} to_STRUCT_{{ function_name }}(const nlohmann::json& j) {
    if (j.is_null() || !j.is_string()) {
        throw std::invalid_argument("Invalid JSON for {{ struct_name }}");
    }
    
    std::string str = j.get<std::string>();
    
    {%- for member in members %}
    if (str == "{{ member.name }}") {
        return {{ function_name }}_{{ member.name }};
    }
    {%- endfor %}
    
    
    throw std::invalid_argument("Unknown value for {{ struct_name }}: " + str);
}

