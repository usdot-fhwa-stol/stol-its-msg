        {%- if s_member.is_optional %}
        if (j["{{ member.name }}"].contains("{{ s_member.name[0] |lower + s_member.name[1:]  }}")) {
            obj.{{ member.name }}->{{ s_member.name }} = new {{ s_member.struct_name }};
            *(obj.{{ member.name }}->{{ s_member.name }}) = to_STRUCT_{{  s_member.function_name }}(j["{{ member.name }}"]["{{ s_member.name[0] | lower + s_member.name[1:] }}"]);
        } else{
            obj.{{ member.name }}->{{ s_member.name }} = nullptr;  // or handle as needed
        }
        {%- else %}
