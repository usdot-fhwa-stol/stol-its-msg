        obj.{{member.name}}->list.array = new {{member.element_struct_name}}*[obj.{{member.name}}->list.count];

        for(int i=0;i<obj.{{member.name}}->list.count;++i){
            obj.{{member.name}}->list.array[i] = new {{member.element_struct_name}}(to_STRUCT_{{member.element_function_name}}(j["{{member.name}}"][i]));
        }

