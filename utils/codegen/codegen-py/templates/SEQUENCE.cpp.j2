json to_JSON_{{function_name}}(const {{struct_name}}& obj) {
    json j;

   
    {% for member in members %}
    {%- if member.item_type == 'simple' %}
    {%- if member.is_optional %}
    if (obj.{{ member.name }} != NULL) {
        {% if member.data_type == "bool" %}
        j["{{ member.name }}"] = static_cast<bool>(*(obj.{{ member.name }}));
        {% else %}
        j["{{ member.name }}"] = static_cast<long>(*(obj.{{ member.name }}));
        {% endif %}
    }
    {%- else %}
    {% if member.data_type == "bool" %}
    j["{{ member.name }}"] = static_cast<bool>((obj.{{ member.name }}));
    {% else %}
    j["{{ member.name }}"] = static_cast<long>((obj.{{ member.name }}));
    {% endif %}
    {%- endif %}
    {%- elif member.item_type == 'complex' %}
    {%- if member.is_optional %}
    if (obj.{{ member.name }} != NULL) {
        json {{ member.name }}_json = to_JSON_{{  member.function_name }}(*obj.{{ member.name }});
        j["{{ member.name[0] |lower + member.name[1:] }}"] = {{ member.name }}_json;
    } 
    {%- else %}
    json {{ member.name }}_json = to_JSON_{{  member.function_name }}(obj.{{ member.name }});
    j["{{ member.name[0] |lower + member.name[1:] }}"] = {{ member.name }}_json;
    {%- endif %}
    {% elif member.item_type =="sequence" %}
    {% if member.is_optional %}
    if (obj.{{ member.name }} != NULL) {
        {% for s_member in member.members %}
        {%- if s_member.item_type == 'simple' %}
        {%- if s_member.is_optional %}
        if (obj.{{ member.name }} != NULL) {
            {% if s_member.data_type == "bool" %}
            j["{{ s_member.name }}"] = static_cast<bool>(*(obj.{{ s_member.name }}));
            {% else %}
            j["{{ s_member.name }}"] = static_cast<long>(*(obj.{{ s_member.name }}));
            {% endif %}
        }
        {%- else %}
        {% if s_member.data_type == "bool" %}
        j["{{ s_member.name }}"] = static_cast<bool>((obj.{{ s_member.name }}));
        {% else %}
        j["{{ s_member.name }}"] = static_cast<long>((obj.{{ s_member.name }}));
        {% endif %}
        {%- endif %}
        {%- elif s_member.item_type == 'complex' %}
        {%- if s_member.is_optional %}
        if (obj.{{member.name}}->{{ s_member.name }} != NULL) {
            json {{ s_member.name }}_json = to_JSON_{{  s_member.function_name }}(*obj.{{member.name}}->{{ s_member.name }});
            j["{{ s_member.name[0] |lower + s_member.name[1:] }}"] = {{ s_member.name }}_json;
        } 
        {%- else %}
        json {{ s_member.name }}_json = to_JSON_{{  s_member.function_name }}(obj.{{member.name}}->{{ s_member.name }});
        j["{{ s_member.name[0] |lower + s_member.name[1:] }}"] = {{ s_member.name }}_json;
        {%- endif %}
        {%- endif %}
        {% endfor %}
    }
    {% else %}
    {% for s_member in member.members %}
    {%- if s_member.item_type == 'simple' %}
    {%- if s_member.is_optional %}
    if (obj.{{ member.name }} != NULL) {
        {% if s_member.data_type == "bool" %}
        j["{{ s_member.name }}"] = static_cast<bool>(*(obj.{{ s_member.name }}));
        {% else %}
        j["{{ s_member.name }}"] = static_cast<long>(*(obj.{{ s_member.name }}));
        {% endif %}
    }
    {%- else %}
    {% if s_member.data_type == "bool" %}
    j["{{ s_member.name }}"] = static_cast<bool>((obj.{{ s_member.name }}));
    {% else %}
    j["{{ s_member.name }}"] = static_cast<long>((obj.{{ s_member.name }}));
    {% endif %}
    {%- endif %}
    {%- elif s_member.item_type == 'complex' %}
    {%- if s_member.is_optional %}
    if (obj.{{member.name}}->{{ s_member.name }} != NULL) {
        json {{ s_member.name }}_json = to_JSON_{{  s_member.function_name }}(*obj.{{member.name}}->{{ s_member.name }});
        j["{{ s_member.name[0] |lower + s_member.name[1:] }}"] = {{ s_member.name }}_json;
    } 
    {%- else %}
    json {{ s_member.name }}_json = to_JSON_{{  s_member.function_name }}(obj.{{member.name}}->{{ s_member.name }});
    j["{{ s_member.name[0] |lower + s_member.name[1:] }}"] = {{ s_member.name }}_json;
    {%- endif %}
    {%- endif %}
    {% endfor %}
    {% endif %}
    {% elif member.item_type == "choice"%}
    {% if member.is_optional %}
    if (obj.{{ member.name }} != NULL) {
        json j_{{member.name}};

        switch (obj.{{member.name}}->present){
            case {{member.struct_name}}_PR_NOTHING:{
                j_{{member.name}} = nullptr;
                break;
            }
            {% for choice in member.choices %}
            case {{member.struct_name}}_PR_{{choice.name}}:{
                j_{{member.name}}["{{choice.name}}"] = to_JSON_{{choice.function_name}}(obj.{{member.name}}->choice.{{choice.name}});
                break;
            }
            {% endfor %}
            default:
                throw std::runtime_error("Unknown choice type");
        }
        j["{{member.name}}"] = j_{{member.name}};
    }
    {% else %}
    json j_{{member.name}};
    switch (obj.{{member.name}}.present){
        case {{member.struct_name}}_PR_NOTHING:{
            j_{{member.name}} = nullptr;
            break;
        }
        {% for choice in member.choices %}
        case {{member.struct_name}}_PR_{{choice.name}}:{
            j_{{member.name}}["{{choice.name}}"] = to_JSON_{{choice.function_name}}(obj.{{member.name}}.choice.{{choice.name}});
            break;
        }
        {% endfor %}
        default:{
            throw std::runtime_error("Unknown choice type");
        }
    }
    j["{{member.name}}"] = j_{{member.name}};
    {% endif %}
    {% elif member.item_type == "sequence_of" %}
    {% if member.is_optional %}
    if (obj.{{ member.name }}!= NULL ) {
        json j_{{member.name}}=json::array();

        for(int i=0;i<obj.{{ member.name }}->list.count;++i){
            const {{member.element_struct_name}}* item = obj.{{ member.name }}->list.array[i];
            j_{{member.name}}.push_back(to_JSON_{{member.element_function_name}}(*item));
        }

        j["{{member.name}}"] = j_{{member.name}};
    }
    {% else %}
    json j_{{member.name}}=json::array();

    for(int i=0;i<obj.{{ member.name }}.list.count;++i){
        const {{member.element_struct_name}}* item = obj.{{ member.name }}.list.array[i];
        j_{{member.name}}.push_back(to_JSON_{{member.element_function_name}}(*item));
    }

    j["{{member.name}}"] = j_{{member.name}};
    {% endif %}
    {%- endif %}
    {% endfor %}
    return j;
}

{{struct_name}} to_STRUCT_{{function_name}}(const json& j) {
    {{struct_name}} obj;
    {% for member in members %}
    {%- if member.item_type == 'simple' %}
    {%- if member.is_optional %}
    if (j.contains("{{ member.name }}")) {
        {% if member.data_type == "bool" %}
        obj.{{member.name}} = new BOOLEAN_t(j.at("{{ member.name }}").get<bool>() ? 1 : 0);
        {% else %}
        obj.{{member.name}} = new long(j.at("{{ member.name }}").get<long>());
        {% endif %}
    } else{
        obj.{{ member.name }} = nullptr;  // or handle as needed
    }
    {%- else %}
    {% if member.data_type == "bool" %}
    obj.{{ member.name }} = new BOOLEAN_t(j.at("{{ member.name }}").get<bool>() ? 1 : 0);
