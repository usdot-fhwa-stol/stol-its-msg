        if(j["{{member.name}}"].contains("{{choice.name}}")) {
            obj.{{member.name}}->present = {{member.struct_name}}_PR_{{choice.name}};
            obj.{{member.name}}->choice.{{choice.name}} = to_STRUCT_{{choice.function_name}}(j["{{member.name}}"]["{{choice.name}}"]);
