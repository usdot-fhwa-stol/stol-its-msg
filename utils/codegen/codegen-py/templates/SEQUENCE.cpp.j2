    {%- if member.is_optional %}
    if (j.contains("{{ member.name[0] |lower + member.name[1:]  }}")) {
        obj.{{ member.name }} = new {{ member.struct_name }};
        *(obj.{{ member.name }}) = to_STRUCT_{{  member.function_name }}(j["{{ member.name[0] | lower + member.name[1:] }}"]);
    } else{
        obj.{{ member.name }} = nullptr;  // or handle as needed
    }
    {%- else %}
